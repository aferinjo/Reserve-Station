ent-BaseXenomorphOrgan = { ent-BaseItem }
    .desc = { ent-BaseItem.desc }

ent-OrganXenomorphBrain = мозг
    .desc = Мы едва ли понимаем, как устроен мозг наземных животных. Кто знает, что мы можем найти в мозге столь высокоразвитого вида?
    .suffix = { roles-antag-xenomorph-name }

ent-OrganXenomorphEyes = глаза
    .desc = Оказалось, они у них всё-таки были!
    .suffix = { roles-antag-xenomorph-name }

ent-OrganXenomorphTongue = язык
    .desc = По мнению ведущих ксенобиологов, эволюционное преимущество наличия второго рта заключается в том, что он «выглядит круто».
    .suffix = { roles-antag-xenomorph-name }

ent-OrganXenomorphStomach = желудок
    .desc = Его стенки способны как значительно расширяться, так и сжиматься с огромной силой.
    .suffix = { roles-antag-xenomorph-name }

ent-OrganXenomorphLiver = печень
    .desc = Печень, принадлежавшая инопланетному убийце, который, кто знает, чем питался.
    .suffix = { roles-antag-xenomorph-name }

ent-OrganXenomorphAcidGland = кислотная железа
    .desc = Специализированный резервуар с кислотой. Образующаяся едкая смесь способна плавить большинство известных материалов.
    .suffix = { roles-antag-xenomorph-name }

ent-OrganXenomorphNeurotoxinGland = нейротоксиновая железа
    .desc = Специализированный резервуар с нейротоксином. Состоит из множества микроскопических трубок, заполненных прозрачной жидкостью.
    .suffix = { roles-antag-xenomorph-name }

ent-OrganXenomorphEggSack = мешок для яиц
    .desc = Предназначен для производства и хранения яиц, содержащих лицехватов. Огромные размеры органа позволяют Королеве ксеноморфов откладывать тысячи яиц в течение короткого периода времени.
    .suffix = { roles-antag-xenomorph-name }

ent-OrganXenomorphResinSpinner = смоляной прядильщик
    .desc = Предназначен для производства и выделения смолоподобного биополимера.
    .suffix = { roles-antag-xenomorph-name }

ent-OrganXenomorphHiveNode = узел улья
    .desc = Центральный орган ксеноморфов, обеспечивающий связь с общим разумом.
    .suffix = { roles-antag-xenomorph-name }

ent-OrganXenomorphPlasmaVessel = хранилище плазмы
    .desc = Резервуар, содержащий концентрированную и высокоактивную плазму — основной источник энергии и сырья для биологического оружия ксеноморфа.
    .suffix = { roles-antag-xenomorph-name }

ent-OrganXenomorphPlasmaVesselLarge = большое хранилище плазмы
    .desc = { ent-OrganXenomorphPlasmaVessel.desc }
    .suffix = { roles-antag-xenomorph-name }

ent-OrganXenomorphPlasmaVesselLargeQueen = { ent-OrganXenomorphPlasmaVesselLarge }
    .desc = { ent-OrganXenomorphPlasmaVesselLarge.desc }
    .suffix = { roles-antag-xenomorph-name }

ent-OrganXenomorphPlasmaVesselSmall = маленькое хранилище плазмы
    .desc = { ent-OrganXenomorphPlasmaVessel.desc }
    .suffix = { roles-antag-xenomorph-name }

ent-OrganXenomorphPlasmaVesselTiny = крошечное хранилище плазмы
    .desc = { ent-OrganXenomorphPlasmaVesselTiny.desc }
    .suffix = { roles-antag-xenomorph-name }
